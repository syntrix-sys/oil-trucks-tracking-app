# ── Mock server WebSocket URL ────────────────────────────────────────────────
# Local dev default — change to ws://<server-ip>:8080 for a remote server,
# or wss://<domain>/ws if running behind a TLS reverse-proxy.
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# ── Mock server HTTP URL (REST endpoints) ────────────────────────────────────
# Derived automatically from NEXT_PUBLIC_WS_URL if left blank (ws→http, wss→https).
# Set explicitly when your HTTP and WS endpoints live on different hosts/ports.
# NEXT_PUBLIC_HTTP_URL=http://localhost:8080

# ── OSRM road-routing server ─────────────────────────────────────────────────
# Defaults to the free public demo (https://router.project-osrm.org).
# Replace with your own self-hosted OSRM instance for production.
# NEXT_PUBLIC_OSRM_URL=https://router.project-osrm.org/route/v1/driving
