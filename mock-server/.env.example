# ── OilTrack Pro Mock Server ─────────────────────────────────────────────────

# Port the WebSocket + HTTP server listens on
PORT=8080

# Tick interval in milliseconds (lower = faster simulation)
TICK_INTERVAL_MS=2000

# Path to the seed data JSON file (absolute or relative to dist/src/)
# SEED_FILE=./src/seed-data.json
