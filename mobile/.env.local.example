# ── OilTrack Pro Mobile (Expo) ────────────────────────────────────────────────
# HTTP base URL of the mock server.
# The WS URL is derived automatically: http → ws, https → wss.
#
# Local dev options:
#   Android emulator  → http://10.0.2.2:8080
#   iOS simulator     → http://localhost:8080
#   Physical device   → http://<your-computer-LAN-IP>:8080
#     Windows: run "ipconfig" → look for IPv4 Address under your Wi-Fi adapter
#     macOS/Linux: run "ifconfig" → look for inet under en0/wlan0
#   The device and your computer MUST be on the same Wi-Fi network.
#
# Remote server: replace with your deployed server URL (http or https).
EXPO_PUBLIC_SERVER_URL=http://192.168.100.108:8080
