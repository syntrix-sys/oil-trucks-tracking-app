# URL of the mock server
# For Android emulator, use: http://10.0.2.2:8080
# For a physical device (Expo Go), replace with your computer's LAN IP:
#   Windows → run "ipconfig" and look for IPv4 Address
#   macOS/Linux → run "ifconfig" and look for inet
# The device and your computer must be on the SAME Wi-Fi network.
EXPO_PUBLIC_SERVER_URL=http://192.168.x.x:8080
